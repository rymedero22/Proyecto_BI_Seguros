  <step>
    <name>Generar Calendario De Análisis</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>SEGUROS_BI</connection>
    <sql>WITH fechas_fuente AS (

    SELECT fecha_inicio AS fecha
    FROM seguro_g29969634.registro_contrato

    UNION ALL

    SELECT fecha_fin AS fecha
    FROM seguro_g29969634.registro_contrato

    UNION ALL

    SELECT fecha_evaluacion AS fecha
    FROM seguro_g29969634.recomienda

    UNION ALL

    SELECT fecha_siniestro AS fecha
    FROM seguro_g29969634.registro_siniestro

    UNION ALL

    SELECT fecha_respuesta AS fecha
    FROM seguro_g29969634.registro_siniestro
    WHERE fecha_respuesta IS NOT NULL

    UNION ALL

    SELECT fecha_inicio AS fecha
    FROM seguro_g29969634.meta_comercial

    UNION ALL

    SELECT fecha_fin AS fecha
    FROM seguro_g29969634.meta_comercial
),

limites AS (
    SELECT
        DATE_TRUNC('year', MIN(fecha))::DATE AS fecha_desde,

        (
            DATE_TRUNC('year', MAX(fecha))
            + INTERVAL '1 year'
            - INTERVAL '1 day'
        )::DATE AS fecha_hasta

    FROM fechas_fuente
    WHERE fecha IS NOT NULL
),

calendario AS (
    SELECT
        serie.fecha::DATE AS fecha_completa

    FROM limites l

    CROSS JOIN LATERAL GENERATE_SERIES(
        l.fecha_desde,
        l.fecha_hasta,
        INTERVAL '1 day'
    ) AS serie(fecha)

    WHERE l.fecha_desde IS NOT NULL
      AND l.fecha_hasta IS NOT NULL
)

SELECT
    fecha_completa,

    EXTRACT(YEAR FROM fecha_completa)::INTEGER AS cod_anio,

    EXTRACT(MONTH FROM fecha_completa)::INTEGER AS cod_mes,

    EXTRACT(DAY FROM fecha_completa)::INTEGER AS cod_dia,

    CASE EXTRACT(MONTH FROM fecha_completa)::INTEGER
        WHEN 1 THEN 'ENERO'
        WHEN 2 THEN 'FEBRERO'
        WHEN 3 THEN 'MARZO'
        WHEN 4 THEN 'ABRIL'
        WHEN 5 THEN 'MAYO'
        WHEN 6 THEN 'JUNIO'
        WHEN 7 THEN 'JULIO'
        WHEN 8 THEN 'AGOSTO'
        WHEN 9 THEN 'SEPTIEMBRE'
        WHEN 10 THEN 'OCTUBRE'
        WHEN 11 THEN 'NOVIEMBRE'
        WHEN 12 THEN 'DICIEMBRE'
    END AS desc_mes,

    CASE
        WHEN EXTRACT(MONTH FROM fecha_completa) BETWEEN 1 AND 3
            THEN 'TRIM. 1'

        WHEN EXTRACT(MONTH FROM fecha_completa) BETWEEN 4 AND 6
            THEN 'TRIM. 2'

        WHEN EXTRACT(MONTH FROM fecha_completa) BETWEEN 7 AND 9
            THEN 'TRIM. 3'

        ELSE 'TRIM. 4'
    END AS desc_trimestre,

    CASE
        WHEN EXTRACT(MONTH FROM fecha_completa) BETWEEN 1 AND 6
            THEN 'SEMESTRE 1'

        ELSE 'SEMESTRE 2'
    END AS desc_semestre

FROM calendario
ORDER BY fecha_completa;</sql>
