  <step>
    <name>Leer REGISTRO_SINIESTRO</name>
    <type>TableInput</type>
    <description>Extrae cada siniestro y obtiene las claves naturales relacionadas desde el modelo transaccional.</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>SEGUROS_BI</connection>
    <sql>SELECT
    rs.id_registro_siniestro AS id_registro_siniestro_fuente,
    rs.nro_siniestro,
    rs.nro_contrato,
    rc.cod_producto,
    rc.cod_cliente,
    cl.cod_sucursal,
    rs.fecha_siniestro,
    rs.fecha_respuesta,
    rs.id_rechazo,
    rs.monto_reconocido,
    rs.monto_solicitado,
    1::INTEGER AS cantidad
FROM seguro_g29969634.registro_siniestro rs
JOIN seguro_g29969634.registro_contrato rc
    ON rc.nro_contrato = rs.nro_contrato
JOIN seguro_g29969634.cliente cl
    ON cl.cod_cliente = rc.cod_cliente
ORDER BY rs.id_registro_siniestro;</sql>
